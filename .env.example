# ============================================================
# KONFIGURASI MYSQL (Database utama)
# ============================================================
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=wedding
MYSQL_PORT=3306

# ============================================================
# SESSION SECURITY
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
SESSION_SECRET=your_session_secret_at_least_32_chars_long

# ============================================================
# APP URL
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: Admin user sekarang disimpan di database (bukan .env)
# Jalankan: node scripts/create-admin.js <email> <password> <name>
